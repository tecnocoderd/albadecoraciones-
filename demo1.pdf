<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Factura Personalizable - Alba Decoraciones</title>
    <style>
        :root {
            --primary: #2c3e50;
            --accent: #d35400;
            --bg: #f8f9fa;
            --card-bg: #ffffff;
            --border: #cccccc;
            --text: #2c3e50;
        }

        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
            font-family: Arial, sans-serif;
        }

        body {
            background-color: var(--bg);
            color: var(--text);
            padding: 10px;
            font-size: 12px;
        }

        .container {
            max-width: 750px;
            margin: 0 auto;
        }

        header {
            text-align: center;
            border-bottom: 2px solid var(--primary);
            padding-bottom: 8px;
            margin-bottom: 12px;
        }

        header h1 { font-size: 20px; color: var(--primary); text-transform: uppercase; }
        header p { font-size: 11px; color: #555; margin-top: 2px; }

        .card {
            background: var(--card-bg);
            padding: 10px;
            border-radius: 4px;
            margin-bottom: 10px;
            border: 1px solid var(--border);
        }

        .card h2 {
            font-size: 12px;
            margin-bottom: 6px;
            color: var(--primary);
            text-transform: uppercase;
            border-bottom: 1px solid var(--border);
            padding-bottom: 2px;
        }

        .grid-3 {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
            gap: 8px;
        }

        .form-group {
            display: flex;
            flex-direction: column;
        }

        .form-group label {
            margin-bottom: 1px;
            font-weight: bold;
            font-size: 10px;
        }

        input, select {
            padding: 4px;
            border: 1px solid var(--border);
            border-radius: 3px;
            font-size: 11px;
            width: 100%;
        }

        button {
            background: var(--primary);
            color: white;
            padding: 6px 12px;
            border: none;
            border-radius: 3px;
            cursor: pointer;
            font-weight: bold;
            font-size: 11px;
        }

        button:hover { opacity: 0.9; }
        
        .btn-accent { background: var(--accent); }
        .btn-danger { background: #c0392b; }
        .btn-success { background: #27ae60; }

        .ventana-row {
            display: flex;
            gap: 6px;
            align-items: flex-end;
            background: #f1f2f6;
            padding: 6px;
            border-radius: 4px;
            margin-bottom: 6px;
            border: 1px solid #ddd;
        }

        .ventana-row .form-group {
            flex: 1;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 5px;
            font-size: 11px;
        }

        th, td {
            border: 1px solid var(--border);
            padding: 4px;
            text-align: left;
        }

        th { background: #eaeded; color: var(--primary); font-weight: bold; }

        /* Estilo para que los campos editables dentro de la tabla parezcan texto normal */
        .editable-td input {
            border: 1px dashed transparent;
            background: transparent;
            padding: 4px;
            font-size: 11px;
            color: var(--text);
            width: 100%;
        }

        .editable-td input:hover, .editable-td input:focus {
            border: 1px dashed #999;
            background: #fffdf0;
            outline: none;
        }

        .totales-box {
            text-align: right;
            font-size: 12px;
        }
        .totales-box div { margin: 2px 0; }
        .grand-total { font-size: 14px; font-weight: bold; color: var(--accent); }

        .no-print-actions {
            display: flex;
            gap: 6px;
            margin-bottom: 10px;
            flex-wrap: wrap;
        }

        /* ESTILO PARA IMPRESIÓN Y PDF (MÁXIMA SIMPLICIDAD - 1 HOJA) */
        @media print {
            @page {
                size: portrait;
                margin: 0.5cm;
            }
            body { 
                background: white; 
                color: black; 
                padding: 0; 
                font-size: 10px; 
            }
            .card { border: none; padding: 0; margin-bottom: 8px; }
            .card h2 { font-size: 11px; margin-bottom: 4px; }
            
            /* Ocultar botones, controles de edición y la columna de borrar */
            #selector-ventanas, .no-print-actions, .btn-danger, td:last-child, th:last-child { 
                display: none !important; 
            }
            
            /* En el PDF los inputs se muestran como texto plano sin bordes */
            .editable-td input {
                border: none !important;
                background: transparent !important;
                padding: 0;
                pointer-events: none;
                font-size: 10px;
                color: black;
            }
            
            input { border: none; background: transparent; padding: 0; pointer-events: none; font-size: 10px; }
            table { font-size: 9px; }
            th, td { padding: 4px; border: 1px solid #555; }
            th { background: #f0f0f0 !important; }
            .totales-box { margin-top: 8px; }
            .grand-total { font-size: 12px; color: black; }
            header { padding: 4px 0; margin-bottom: 8px; }
            header h1 { font-size: 16px; }
        }
    </style>
</head>
<body>

<div class="container">
    <header>
        <h1>Alba Decoraciones</h1>
        <p>Teléfonos: 829 263 1340 | 849 856 4191 &bull; Instagram: Albadecoraciones.dom</p>
    </header>

    <div class="card">
        <h2>Datos del Cliente</h2>
        <div class="grid-3">
            <div class="form-group">
                <label>Cliente / Proyecto:</label>
                <input type="text" id="client-name" placeholder="Nombre del cliente">
            </div>
            <div class="form-group">
                <label>Teléfono:</label>
                <input type="text" id="client-phone" placeholder="Teléfono del cliente">
            </div>
            <div class="form-group">
                <label>No. Cotización:</label>
                <input type="text" id="invoice-num" placeholder="0001">
            </div>
        </div>
    </div>

    <div class="card" id="selector-ventanas">
        <h2>Ingresar Medidas de Ventanas (No sale en el PDF)</h2>
        <div id="ventanas-lista"></div>
        <div style="margin-top: 8px;">
            <button type="button" onclick="agregarVentana()">+ Agregar Ventana</button>
        </div>
    </div>

    <div class="no-print-actions">
        <button type="button" class="btn-accent" onclick="agregarArticuloExtra('Bastón de 36 cm', 390)">+ Bastón 36cm (RD$390)</button>
        <button type="button" class="btn-accent" onclick="agregarArticuloExtra('Bastón de 60 cm', 500)">+ Bastón 60cm (RD$500)</button>
        <button type="button" class="btn-accent" onclick="agregarArticuloExtra('Artículo Extra Manual', 0)">+ Agregar Otro Artículo</button>
        <button type="button" class="btn-success" style="margin-left: auto;" onclick="window.print()">Imprimir / Guardar PDF</button>
    </div>

    <div class="card">
        <h2>Detalle de Factura (Puedes hacer clic sobre cualquier celda para editar el texto o precio)</h2>
        <table>
            <thead>
                <tr>
                    <th>Descripción del Concepto / Material / Servicio</th>
                    <th style="width: 70px; text-align: center;">Cant.</th>
                    <th style="width: 120px; text-align: right;">Precio Unit.</th>
                    <th style="width: 120px; text-align: right;">Total</th>
                    <th class="no-print-column" style="width: 40px; text-align: center;">Borrar</th>
                </tr>
            </thead>
            <tbody id="tabla-materiales">
                </tbody>
        </table>
    </div>

    <div class="card totales-box">
        <div class="form-group" style="max-width: 160px; margin-left: auto; margin-bottom: 5px;">
            <label>Descuento Comercial (RD$):</label>
            <input type="number" id="descuento-input" value="0" min="0" style="text-align: right;" oninput="calcularTotalFactura()">
        </div>
        <div>Subtotal: <strong id="subtotal-neto">RD$ 0.00</strong></div>
        <div>Descuento Concedido: <strong id="descuento-total">-RD$ 0.00</strong></div>
        <div class="grand-total" style="margin-top: 4px;">Total a Pagar: <span id="total-general">RD$ 0.00</span></div>
    </div>
</div>

<script>
    // Parámetros Maestros de Precios Unitarios
    const PRECIOS = {
        barra10: 1050, barra12: 1200, barra14: 1250, barra16: 1450,
        blackout: 480, visillo: 300, carritoOndas: 175, cinta: 120,
        soporteTerminales: 500, cintaBroche: 120, carritoTachones: 350, ganchoTachones: 70
    };

    const BARRAS_CM = [
        { label: 'Barra 10 Pies', cm: 304.8, precio: 1050 },
        { label: 'Barra 12 Pies', cm: 365.76, precio: 1200 },
        { label: 'Barra 14 Pies', cm: 426.72, precio: 1250 },
        { label: 'Barra 16 Pies', cm: 487.68, precio: 1450 }
    ];

    let ventanaCount = 0;

    // Crea un bloque de configuración para una ventana en el panel superior
    function agregarVentana() {
        ventanaCount++;
        const lista = document.getElementById('ventanas-lista');
        const div = document.createElement('div');
        div.className = 'ventana-row';
        div.id = `v-row-${ventanaCount}`;
        div.innerHTML = `
            <div class="form-group" style="flex: 1.5;">
                <label>Ubicación / Ref:</label>
                <input type="text" class="v-nombre" value="Ventana ${ventanaCount}" oninput="procesarYRedibujarTabla()">
            </div>
            <div class="form-group" style="width: 70px;">
                <label>Ancho (cm):</label>
                <input type="number" class="v-ancho" value="150" oninput="procesarYRedibujarTabla()">
            </div>
            <div class="form-group" style="width: 70px;">
                <label>Largo (cm):</label>
                <input type="number" class="v-largo" value="200" oninput="procesarYRedibujarTabla()">
            </div>
            <div class="form-group">
                <label>Confección:</label>
                <select class="v-confeccion" onchange="procesarYRedibujarTabla()">
                    <option value="ondas">Ondas</option>
                    <option value="tachones">Tachones</option>
                </select>
            </div>
            <div class="form-group">
                <label>Tipo Tela:</label>
                <select class="v-tela" onchange="procesarYRedibujarTabla()">
                    <option value="visillo">Visillo</option>
                    <option value="blackout">Blackout</option>
                    <option value="doble">Doble</option>
                </select>
            </div>
            <button type="button" class="btn-danger" style="padding: 4px 8px;" onclick="eliminarVentana(${ventanaCount})">X</button>
        `;
        lista.appendChild(div);
        procesarYRedibujarTabla();
    }

    function eliminarVentana(id) {
        const elemento = document.getElementById(`v-row-${id}`);
        if(elemento) elemento.remove();
        procesarYRedibujarTabla();
    }

    // Retorna la barra que se adapta físicamente al hueco
    function obtenerBarra(ancho) {
        for (let b of BARRAS_CM) {
            if (b.cm > ancho) return b;
        }
        return BARRAS_CM[3]; // Fallback barra de 16 pies
    }

    // Ejecuta el algoritmo del dos y medio y dibuja la fila en la tabla de facturas
    function procesarYRedibujarTabla() {
        const tbody = document.getElementById('tabla-materiales');
        
        // Antes de vaciar la tabla, salvaremos las filas manuales adicionales que el usuario haya agregado
        const filasAdicionalesGuardadas = [];
        const filasActuales = tbody.querySelectorAll('tr');
        filasActuales.forEach(f => {
            if (f.classList.contains('fila-adicional') || f.classList.contains('fila-ventana-modificada')) {
                const inputs = f.querySelectorAll('input');
                filasAdicionalesGuardadas.push({
                    esModificada: f.classList.contains('fila-ventana-modificada'),
                    descripcion: inputs[0].value,
                    cantidad: parseFloat(inputs[1].value) || 1,
                    precio: parseFloat(inputs[2].value) || 0
                });
            }
        });

        tbody.innerHTML = '';

        // 1. Procesar y calcular automáticamente cada ventana configurada en el panel superior
        const filasVentanas = document.querySelectorAll('.ventana-row');
        filasVentanas.forEach(f => {
            const nombre = f.querySelector('.v-nombre').value;
            const ancho = parseFloat(f.querySelector('.v-ancho').value) || 0;
            const largo = parseFloat(f.querySelector('.v-largo').value) || 0;
            const confeccion = f.querySelector('.v-confeccion').value;
            const tela = f.querySelector('.v-tela').value;

            if (ancho <= 0) return;

            // Tratamiento de ventanas dobles (Duplicador del Punto 2)
            const esDoble = (tela === 'doble');
            const factorDoble = esDoble ? 2 : 1;

            // Costo de barra(s) e instalación
            const barra = obtenerBarra(ancho);
            const costoSoporteInstalacion = PRECIOS.soporteTerminales * factorDoble;
            const costoBarraTotal = barra.precio * factorDoble;

            // Metraje de tela con la regla del 2.5 convertido a yardas comerciales
            const metrosRiel = ancho / 100;
            const metrosTela = metrosRiel * 2.5;
            let yardas = Math.ceil(metrosTela / 0.9144);
            if (yardas < 1) yardas = 1;

            let costoTelas = 0;
            if (tela === 'visillo' || esDoble) costoTelas += yardas * PRECIOS.visillo;
            if (tela === 'blackout' || esDoble) costoTelas += yardas * PRECIOS.blackout;

            // Accesorios específicos de la confección
            let costoAccesorios = 0;
            if (confeccion === 'ondas') {
                let yardasAccesorios = Math.ceil(yardas * 0.7);
                if (yardasAccesorios < 1) yardasAccesorios = 1;
                costoAccesorios += (yardasAccesorios * PRECIOS.carritoOndas * factorDoble);
                costoAccesorios += (yardas * PRECIOS.cinta * factorDoble);
                costoAccesorios += (yardas * PRECIOS.cintaBroche * factorDoble);
            } else if (confeccion === 'tachones') {
                costoAccesorios += PRECIOS.carritoTachones + PRECIOS.ganchoTachones;
            }

            const precioVentanaCalculada = costoBarraTotal + costoSoporteInstalacion + costoTelas + costoAccesorios;
            const descripcionPorDefecto = `Cortina Completa: ${nombre} (${confeccion.toUpperCase()}, ${tela.toUpperCase()}) - ${ancho}x${largo} cm`;

            // Insertamos la fila auto-calculada que puede ser libremente editada por el usuario
            insertarFilaEnTabla(descripcionPorDefecto, 1, precioVentanaCalculada, false);
        });

        // 2. Restaurar las filas manuales adicionales o modificadas que ya existían
        filasAdicionalesGuardadas.forEach(item => {
            insertarFilaEnTabla(item.descripcion, item.cantidad, item.precio, true);
        });

        calcularTotalFactura();
    }

    // Inserta una fila física editable en el cuerpo de la tabla
    function insertarFilaEnTabla(descripcion, cantidad, precio, esAdicional) {
        const tbody = document.getElementById('tabla-materiales');
        const tr = document.createElement('tr');
        
        // Le asignamos una clase para identificarla si fue agregada manualmente o modificada
        tr.className = esAdicional ? 'fila-adicional' : 'fila-ventana';

        const totalFila = cantidad * precio;

        tr.innerHTML = `
            <td class="editable-td">
                <input type="text" value="${descripcion}" onchange="marcarComoModificado(this)">
            </td>
            <td class="editable-td" style="text-align: center;">
                <input type="number" value="${cantidad}" style="text-align: center;" oninput="actualizarTotalFilaDirecto(this)">
            </td>
            <td class="editable-td">
                <input type="number" value="${precio}" style="text-align: right;" oninput="actualizarTotalFilaDirecto(this)">
            </td>
            <td class="fila-total-calculado" style="text-align: right; font-weight: bold;">
                RD$ ${totalFila.toLocaleString('en-US', {minimumFractionDigits: 2})}
            </td>
            <td class="no-print-column" style="text-align: center;">
                <button type="button" class="btn-danger" style="padding: 2px 6px; font-size: 10px;" onclick="eliminarFilaFactura(this)">X</button>
            </td>
        `;
        tbody.appendChild(tr);
    }

    // Si el usuario edita el nombre de una ventana directamente en la tabla, la separamos del auto-generador
    function marcarComoModificado(input) {
        const fila = input.parentElement.parentElement;
        if (fila.classList.contains('fila-ventana')) {
            fila.classList.remove('fila-ventana');
            fila.classList.add('fila-ventana-modificada'); // Evita que se sobreescriba si cambian los cm en el panel
        }
        calcularTotalFactura();
    }

    // Agrega un artículo extra (como los bastones o campos manuales vacíos)
    function agregarArticuloExtra(nombre, precio) {
        insertarFilaEnTabla(nombre, 1, precio, true);
        calcularTotalFactura();
    }

    // Elimina cualquier fila directamente de la factura
    function eliminarFilaFactura(btn) {
        btn.parentElement.parentElement.remove();
        calcularTotalFactura();
    }

    // Calcula el total de la fila de forma reactiva mientras escribes cantidad o precio
    function actualizarTotalFilaDirecto(input) {
        const fila = input.parentElement.parentElement;
        const inputs = fila.querySelectorAll('input');
        
        // Marcamos como modificada para que no sea reemplazada por el cálculo automático
        if (fila.classList.contains('fila-ventana')) {
            fila.classList.remove('fila-ventana');
            fila.classList.add('fila-ventana-modificada');
        }

        const cant = parseFloat(inputs[1].value) || 0;
        const precio = parseFloat(inputs[2].value) || 0;
        const total = cant * precio;

        fila.querySelector('.fila-total-calculado').innerText = `RD$ ${total.toLocaleString('en-US', {minimumFractionDigits: 2})}`;
        calcularTotalFactura();
    }

    // Calcula los totales generales sumando cada fila existente en la tabla
    function calcularTotalFactura() {
        const filas = document.querySelectorAll('#tabla-materiales tr');
        let subtotal = 0;

        filas.forEach(f => {
            const inputs = f.querySelectorAll('input');
            if (inputs.length >= 3) {
                const cant = parseFloat(inputs[1].value) || 0;
                const precio = parseFloat(inputs[2].value) || 0;
                subtotal += (cant * precio);
            }
        });

        document.getElementById('subtotal-neto').innerText = `RD$ ${subtotal.toLocaleString('en-US', {minimumFractionDigits: 2})}`;
        
        const desc = parseFloat(document.getElementById('descuento-input').value) || 0;
        document.getElementById('descuento-total').innerText = `-RD$ ${desc.toLocaleString('en-US', {minimumFractionDigits: 2})}`;
        
        let total = subtotal - desc;
        if (total < 0) total = 0;
        document.getElementById('total-general').innerText = `RD$ ${total.toLocaleString('en-US', {minimumFractionDigits: 2})}`;
    }

    // Iniciamos con una ventana configurada para arrancar la aplicación
    agregarVentana();
</script>

</body>
</html>